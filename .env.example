# Supabase — populate locally via .env.local and in production via Vercel project env vars.
# Only VITE_* prefixed vars are exposed to the client bundle.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Data source: "local" (hardcoded sample data) or "supabase" (Phase 12).
# Defaults to "local" if unset.
VITE_DATA_SOURCE=local
